generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int            @id @default(autoincrement())
  name           String         @default("Demo User")
  email          String         @unique @default("demo@schedulr.com")
  timezone       String         @default("Asia/Kolkata")
  createdAt      DateTime       @default(now())
  availabilities Availability[]
  eventTypes     EventType[]
  meetings       Meeting[]
}

model EventType {
  id          Int       @id @default(autoincrement())
  userId      Int
  name        String
  slug        String    @unique
  duration    Int
  description String?
  color       String    @default("#0069ff")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  meetings    Meeting[]
}

model Availability {
  id        Int     @id @default(autoincrement())
  userId    Int
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
  user      User    @relation(fields: [userId], references: [id])

  @@unique([userId, dayOfWeek])
}

model Meeting {
  id           Int           @id @default(autoincrement())
  userId       Int
  eventTypeId  Int
  inviteeName  String
  inviteeEmail String
  startTime    DateTime
  endTime      DateTime
  timezone     String        @default("Asia/Kolkata")
  status       MeetingStatus @default(UPCOMING)
  cancelReason String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  eventType    EventType     @relation(fields: [eventTypeId], references: [id])
  user         User          @relation(fields: [userId], references: [id])
}

enum MeetingStatus {
  UPCOMING
  CANCELLED
  COMPLETED
}
